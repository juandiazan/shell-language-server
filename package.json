{
  "name": "bash-lsp",
  "displayName": "Shellscript LS",
  "description": "Language Server for Shell scripting languages",
  "author": "Juan Diaz",
  "license": "MIT",
  "version": "0.1.7",
  "publisher": "juandiazan",
  "repository": {
    "type": "git",
    "url": "https://github.com/juandiazan/shell-language-server.git"
  },
  "categories": [
    "Programming Languages"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "activationEvents": [
    "onLanguage:shellscript"
  ],
  "main": "./client/out/extension",
  "contributes": {
    "configuration": {}
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run bundle",
    "compile": "tsc -b",
    "bundle": "esbuild client/src/extension.ts --bundle --outfile=client/out/extension.js --external:vscode --format=cjs --platform=node --target=node16 --minify",
    "watch": "tsc -b -w",
    "version": "node scripts/sync-version.js && git add server/package.json",
    "postinstall": "node -e \"const f=require('fs');if(f.existsSync('client/package.json')){require('child_process').execSync('npm install',{cwd:'client',stdio:'inherit'})}\"",
    "lint": "eslint 'client/src/**/*.ts' 'server/src/**/*.ts'",
    "format": "prettier --write 'client/src/**/*.ts' 'server/src/**/*.ts'",
    "format:check": "prettier --check 'client/src/**/*.ts' 'server/src/**/*.ts'"
  },
  "devDependencies": {
    "@types/node": "^20.5.7",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^5.2.2"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
